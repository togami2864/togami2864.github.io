---
import { BlogBaseHead } from '@components/BlogBaseHead.tsx';
import BlogHeader from '@components/BlogHeader.astro';
import BlogPost from '@components/BlogPost.astro';
import Button from '@components/Button.astro';
import Footer from '@components/Footer.astro'

import { getHeroImage } from '../utils/getHeroImage';

const { title, description, publishDate, author, permalink, alt , lang, i18 , filename} = Astro.props.content;
const heroImage = getHeroImage();
---

<html lang={lang}>
  <head>
    <BlogBaseHead title={title} description={description} permalink={permalink} filename={filename} lang={lang} />
    <link rel="stylesheet" href="/blog.css" />
  </head>

  <body>
    <BlogHeader lang={lang} translation={i18}/>
    <BlogPost {title} {author} {heroImage} {publishDate} {alt} {lang} {i18}>
      <slot />
    </BlogPost>
    <Button/>
    <Footer/>
  </body>
</html>
